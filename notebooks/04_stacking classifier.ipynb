        "# Sentence embeddings (SBERT) with GPU + cache for faster reruns\n",
        "from sentence_transformers import SentenceTransformer\n",
        "import os\n",
        "import numpy as np\n",
        "import torch\n",
        "\n",
        "cache_dir = \"../data/processed\"\n",
        "os.makedirs(cache_dir, exist_ok=True)\n",
        "train_cache_path = os.path.join(cache_dir, \"X_train_embed_minilm.npy\")\n",
        "test_cache_path = os.path.join(cache_dir, \"X_test_embed_minilm.npy\")\n",
        "\n",
        "device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
        "# Restore faster CPU default (64) and use larger batches on GPU.\n",
        "# Optional override from env, e.g. os.environ[\"SBERT_BATCH_SIZE\"] = \"96\"\n",
        "default_batch_size = 256 if device == \"cuda\" else 64\n",
        "batch_size = int(os.environ.get(\"SBERT_BATCH_SIZE\", default_batch_size))\n",
        "\n",
        "model_st = SentenceTransformer(\"all-MiniLM-L6-v2\", device=device)\n",
        "\n",
        "if os.path.exists(train_cache_path) and os.path.exists(test_cache_path):\n",
        "    print(\"Loading cached embeddings...\")\n",
        "    X_train_embed = np.load(train_cache_path)\n",
        "    X_test_embed = np.load(test_cache_path)\n",
        "else:\n",
        "    print(f\"Encoding on {device} (batch_size={batch_size})...\")\n",
        "    X_train_embed = model_st.encode(\n",
        "        X_train.tolist(),\n",
        "        show_progress_bar=True,\n",
        "        batch_size=batch_size,\n",
        "        convert_to_numpy=True,\n",
        "    )\n",
        "    X_test_embed = model_st.encode(\n",
        "        X_test.tolist(),\n",
        "        show_progress_bar=True,\n",
        "        batch_size=batch_size,\n",
        "        convert_to_numpy=True,\n",
        "    )\n",
        "    np.save(train_cache_path, X_train_embed)\n",
        "    np.save(test_cache_path, X_test_embed)\n",
        "    print(\"Saved embeddings cache.\")"
      ]
    },
